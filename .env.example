# ---- Backend (Vercel serverless functions in /api) ----
# Your Anthropic API key. Set this in the Vercel project's Environment Variables,
# NOT in the client. It must never ship in the app bundle.
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides (TRD §6). Defaults shown.
# Fast/warm generations (reframe, questions, affirmations):
ANTHROPIC_MODEL=claude-sonnet-4-6
# The future-self letter (richer model):
ANTHROPIC_MODEL_LETTER=claude-opus-4-8

# ---- Client (Expo) ----
# Point the app at your deployed backend. Leave blank to use the on-device mock.
# Example: https://reverie.vercel.app  (the app appends /api/<endpoint>)
EXPO_PUBLIC_API_BASE_URL=
